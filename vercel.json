{
  "functions": {
    "api/tracker-data.js": {
      "includeFiles": "PROPOSALS.md"
    }
  },
  "redirects": [
    {
      "source": "/dream",
      "destination": "https://dream.noahglynn.com/",
      "permanent": false
    },
    {
      "source": "/dream/",
      "destination": "https://dream.noahglynn.com/",
      "permanent": false
    },
    {
      "source": "/dream/index.html",
      "destination": "https://dream.noahglynn.com/",
      "permanent": false
    },
    {
      "source": "/dream/about",
      "destination": "https://dream.noahglynn.com/about",
      "permanent": false
    },
    {
      "source": "/dream/about/",
      "destination": "https://dream.noahglynn.com/about",
      "permanent": false
    },
    {
      "source": "/dream/about/index.html",
      "destination": "https://dream.noahglynn.com/about",
      "permanent": false
    }
  ],
  "routes": [
    { "src": "/\\.pi(?:/.*)?", "status": 404, "dest": "/404.html" },
    { "src": "/\\.finance(?:/.*)?", "status": 404, "dest": "/404.html" },
    { "src": "/.*\\.md", "status": 404, "dest": "/404.html" },
    { "src": "/.*\\.json", "status": 404, "dest": "/404.html" },
    { "src": "/docs(?:/.*)?", "status": 404, "dest": "/404.html" },
    { "src": "/design(?:/.*)?", "status": 404, "dest": "/404.html" },
    { "src": "/scripts(?:/.*)?", "status": 404, "dest": "/404.html" },
    { "src": "/tools(?:/.*)?", "status": 404, "dest": "/404.html" },
    { "handle": "filesystem" }
  ]
}
